DATABASE_URL=postgresql+psycopg://rag:rag@localhost:5432/ragdb
APP_ENV=dev
LOG_LEVEL=INFO

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM provider (used for answer generation and (optional) query rewrite)
LLM_PROVIDER=openai_compat
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=YOUR_KEY_HERE
LLM_MODEL=gpt-4o-mini
# Optional JSON map for per-request model profile selection.
# Example:
# LLM_PROFILES_JSON={"gpt4o":{"provider":"openai_compat","base_url":"https://api.openai.com/v1","api_key_env":"LLM_API_KEY","model":"gpt-4o"}}
LLM_PROFILES_JSON=
# Optional override for prompt files (absolute path or repo-relative path).
# Case-level prompt profiles in config/rag_cases.yml take precedence.
SYSTEM_PERSONA_PATH=
ANSWER_TEMPLATE_PATH=
NEXT_GEN_RAG_ENABLED=false
RAG_CASES_PATH=config/rag_cases.yml
INSTANCE_CASE_IDS_JSON=
CELL_ACCESS_CONTROL_ENABLED=false
CELL_GATEWAY_SHARED_SECRET=
# JSON array of scaffold owner user IDs with full owner rights across RAG cases.
CELL_OWNER_USER_IDS_JSON=[]
RESEARCH_API_TOKENS_JSON=
RESEARCH_DOWNLOAD_SIGNING_KEY=
RESEARCH_DOWNLOAD_TTL_SECONDS=300

# Admin API security
ADMIN_API_KEY=CHANGE_ME_TO_A_LONG_RANDOM_VALUE
INGEST_ROOT=/data/uploads
SYNC_TOMBSTONE_ENABLED=false
SYNC_TOMBSTONE_GRACE_SECONDS=900
SYNC_ANTI_THRASH_BATCH_SIZE=200

# Retrieval tuning
TOP_K_VECTOR=50
TOP_K_LEXICAL=50
TOP_K_FINAL=12
MAX_CHUNKS_PER_DOC=3

# Optional: query rewrite (uses LLM)
QUERY_REWRITE_ENABLED=true

# Optional: query router (project docs vs prompt instructions)
QUERY_ROUTER_ENABLED=true
QUERY_ROUTER_DOCS_SOURCE_TYPES_JSON=["universe_status","universe_tools","universe_argumentation"]
QUERY_ROUTER_PROMPTS_SOURCE_TYPES_JSON=["universe_prompts"]
QUERY_ROUTER_DOCS_KEYWORDS_JSON=["status","simulering","simulation","graf","graph","parameter","trajectory","ctmc","ssa","hypotese","observabel","metastabilitet","lorentz","energi"]
QUERY_ROUTER_PROMPTS_KEYWORDS_JSON=["prompt","prompts","system prompt","persona","template","mal","instruksjon","instruction","language model","llm"]

# Optional: reranking (cross-encoder). Requires `pip install -e '.[emb]'`
RERANKER_ENABLED=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Grounding gate
GROUNDING_MIN_CITATIONS=2

# Streaming
STREAM_CHUNK_CHARS=80
